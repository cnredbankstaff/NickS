function buildParkour(difficulty) {
  platforms = [];
  portals = [];
  crystals = [];
  signs = [];
  enemies = [];
  mazeWalls = [];

  let platW, platD, gapMin, gapMax, count, moving;
  if (difficulty === 'easy') {
    platW = 2.5; platD = 2.5; gapMin = 2; gapMax = 3.5; count = 15; moving = 0;
  } else if (difficulty === 'medium') {
    platW = 1.8; platD = 1.8; gapMin = 2.5; gapMax = 4; count = 20; moving = 5;
  } else {
    platW = 1.2; platD = 1.2; gapMin = 3; gapMax = 5; count = 25; moving = 10;
  }

  // Start platform
  platforms.push({ x:0, y:0, z:0, w:4, h:1, d:4, color:'#1a1a2e', top:'#22c55e', side:'#166534' });

  let px = 0, pz = 0, py = 0;
  for (let i = 0; i < count; i++) {
    const dir = Math.random() > 0.5 ? 1 : -1;
    const gap = gapMin + Math.random() * (gapMax - gapMin);
    const heightChange = (Math.random() - 0.3) * 1.5;

    if (Math.random() > 0.5) {
      pz -= gap;
    } else {
      px += dir * gap;
    }
    py = Math.max(0, py + heightChange);

    const isMoving = i >= count - moving;
    platforms.push({
      x: px, y: py, z: pz,
      w: platW, h: 0.5, d: platD,
      color: '#374151', top: isMoving ? '#f59e0b' : '#6b7280', side: '#1f2937',
      moving: isMoving,
      moveAxis: Math.random() > 0.5 ? 'x' : 'z',
      moveRange: 1.5 + Math.random() * 1.5,
      moveSpeed: 1 + Math.random(),
      baseX: px, baseZ: pz
    });
  }

  // End platform
  pz -= 4;
  platforms.push({ x:px, y:py, z:pz, w:4, h:1, d:4, color:'#1a1a2e', top:'#fbbf24', side:'#92400e', isEnd: true });

  // Crystals along the path
  for (let i = 0; i < 30; i++) {
    const rp = platforms[Math.floor(Math.random() * platforms.length)];
    crystals.push({
      x: rp.x + (Math.random()-0.5)*8,
      y: rp.y - 5 + Math.random()*3,
      z: rp.z + (Math.random()-0.5)*8,
      color: ['#00ffc8','#ff6b6b','#a78bfa','#f97316'][Math.floor(Math.random()*4)],
      size: 0.3 + Math.random()*0.5
    });
  }

  // Lava below
  platforms.push({ x:0, y:-15, z:0, w:200, h:0.5, d:200, color:'#dc2626', top:'#f97316', side:'#991b1b', isLava: true });

  player.x = 0; player.y = 2; player.z = 0;
  camera.yaw = Math.PI; camera.pitch = 0.3;
}

function buildMaze() {
  platforms = [];
  portals = [];
  crystals = [];
  signs = [];
  enemies = [];
  mazeWalls = [];

  const SIZE = 15;
  const CELL = 3;

  // Generate maze using recursive backtracking
  mazeGrid = [];
  for (let r = 0; r < SIZE; r++) {
    mazeGrid[r] = [];
    for (let c = 0; c < SIZE; c++) {
      mazeGrid[r][c] = { visited: false, walls: { n:true, s:true, e:true, w:true } };
    }
  }

  const stack = [];
  let cr = 0, cc = 0;
  mazeGrid[cr][cc].visited = true;
  stack.push([cr, cc]);

  while (stack.length > 0) {
    const neighbors = [];
    if (cr > 0 && !mazeGrid[cr-1][cc].visited) neighbors.push([cr-1, cc, 'n', 's']);
    if (cr < SIZE-1 && !mazeGrid[cr+1][cc].visited) neighbors.push([cr+1, cc, 's', 'n']);
    if (cc > 0 && !mazeGrid[cr][cc-1].visited) neighbors.push([cr, cc-1, 'w', 'e']);
    if (cc < SIZE-1 && !mazeGrid[cr][cc+1].visited) neighbors.push([cr, cc+1, 'e', 'w']);

    if (neighbors.length > 0) {
      const [nr, nc, wall, opp] = neighbors[Math.floor(Math.random() * neighbors.length)];
      mazeGrid[cr][cc].walls[wall] = false;
      mazeGrid[nr][nc].walls[opp] = false;
      mazeGrid[nr][nc].visited = true;
      stack.push([cr, cc]);
      cr = nr; cc = nc;
    } else {
      [cr, cc] = stack.pop();
    }
  }

  // Floor
  const totalSize = SIZE * CELL;
  platforms.push({ x: totalSize/2, y: -0.5, z: totalSize/2, w: totalSize + 4, h: 1, d: totalSize + 4, color: '#1a1a2e', top: '#1e293b', side: '#0f172a' });

  // Build walls from maze grid
  const wallH = 3.5;
  const wallT = 0.3;
  for (let r = 0; r < SIZE; r++) {
    for (let c = 0; c < SIZE; c++) {
      const cx = c * CELL + CELL / 2;
      const cz = r * CELL + CELL / 2;
      const cell = mazeGrid[r][c];

      if (cell.walls.n) {
        mazeWalls.push({ x: cx, y: wallH/2, z: cz - CELL/2, w: CELL + wallT, h: wallH, d: wallT });
      }
      if (cell.walls.s) {
        mazeWalls.push({ x: cx, y: wallH/2, z: cz + CELL/2, w: CELL + wallT, h: wallH, d: wallT });
      }
      if (cell.walls.w) {
        mazeWalls.push({ x: cx - CELL/2, y: wallH/2, z: cz, w: wallT, h: wallH, d: CELL + wallT });
      }
      if (cell.walls.e) {
        mazeWalls.push({ x: cx + CELL/2, y: wallH/2, z: cz, w: wallT, h: wallH, d: CELL + wallT });
      }
    }
  }

  // Exit at far corner
  mazeExit = { x: (SIZE - 1) * CELL + CELL / 2, y: 0, z: (SIZE - 1) * CELL + CELL / 2, w: 2, d: 2 };

  // Enemies
  const enemyCount = 3;
  for (let i = 0; i < enemyCount; i++) {
    const er = Math.floor(SIZE/3) + Math.floor(Math.random() * (SIZE/2));
    const ec = Math.floor(SIZE/3) + Math.floor(Math.random() * (SIZE/2));
    enemies.push({
      x: ec * CELL + CELL/2, y: 0.5, z: er * CELL + CELL/2,
      speed: 1.5 + Math.random() * 0.5,
      targetX: 0, targetZ: 0
    });
  }

  // Dim crystals
  for (let i = 0; i < 40; i++) {
    crystals.push({
      x: Math.random() * totalSize,
      y: 0,
      z: Math.random() * totalSize,
      color: ['#3b82f6','#6366f1','#8b5cf6'][Math.floor(Math.random()*3)],
      size: 0.15 + Math.random() * 0.2
    });
  }

  player.x = CELL / 2; player.y = 1.5; player.z = CELL / 2;
  camera.yaw = 0; camera.pitch = 0.3;
}

// ============================================================
// PHYSICS
// ============================================================

function updatePhysics(dt) {
  // Movement direction based on camera yaw
  let mx = 0, mz = 0;
  if (keys['KeyW'] || keys['ArrowUp']) { mx += Math.sin(camera.yaw); mz += Math.cos(camera.yaw); }
  if (keys['KeyS'] || keys['ArrowDown']) { mx -= Math.sin(camera.yaw); mz -= Math.cos(camera.yaw); }
  if (keys['KeyA'] || keys['ArrowLeft']) { mx += Math.cos(camera.yaw); mz -= Math.sin(camera.yaw); }
  if (keys['KeyD'] || keys['ArrowRight']) { mx -= Math.cos(camera.yaw); mz += Math.sin(camera.yaw); }

  const len = Math.sqrt(mx*mx + mz*mz);
  if (len > 0) { mx /= len; mz /= len; }

  player.vx = mx * player.speed;
  player.vz = mz * player.speed;

  // Jump
  if ((keys['Space']) && player.grounded) {
    player.vy = player.jumpForce;
    player.grounded = false;
  }

  // Gravity
  player.vy += GRAVITY * dt;

  // Apply velocity
  player.x += player.vx * dt;
  player.y += player.vy * dt;
  player.z += player.vz * dt;

  // Platform collision
  player.grounded = false;

  // Update moving platforms
  const time = Date.now() / 1000;
  platforms.forEach(p => {
    if (p.moving) {
      if (p.moveAxis === 'x') p.x = p.baseX + Math.sin(time * p.moveSpeed) * p.moveRange;
      else p.z = p.baseZ + Math.sin(time * p.moveSpeed) * p.moveRange;
    }
  });

  const allCollidables = [...platforms.filter(p => !p.isLava && !p.glow), ...mazeWalls.map(w => ({...w, color:'#374151', top:'#4b5563', side:'#1f2937'}))];

  for (const p of allCollidables) {
    const hw = p.w / 2, hd = p.d / 2;
    const pLeft = p.x - hw, pRight = p.x + hw;
    const pFront = p.z - hd, pBack = p.z + hd;
    const pTop = p.y + (p.h || 0);
    const pBottom = p.y;

    const pw = player.width / 2;

    // Check if player overlaps horizontally
    if (player.x + pw > pLeft && player.x - pw < pRight &&
        player.z + pw > pFront && player.z - pw < pBack) {

      // Landing on top
      if (player.y - 0.8 <= pTop && player.y - 0.8 > pTop - 0.5 && player.vy <= 0) {
        player.y = pTop + 0.8;
        player.vy = 0;
        player.grounded = true;

        // Check if end platform (parkour)
        if (p.isEnd && gameState === 'parkour') {
          winParkour();
        }
      }
      // Side collisions
      else if (player.y - 0.8 < pTop && player.y + 0.8 > pBottom) {
        // Push player out
        const overlapLeft = (player.x + pw) - pLeft;
        const overlapRight = pRight - (player.x - pw);
        const overlapFront = (player.z + pw) - pFront;
        const overlapBack = pBack - (player.z - pw);

        const minOverlap = Math.min(overlapLeft, overlapRight, overlapFront, overlapBack);
        if (minOverlap === overlapLeft) player.x = pLeft - pw;
        else if (minOverlap === overlapRight) player.x = pRight + pw;
        else if (minOverlap === overlapFront) player.z = pFront - pw;
        else player.z = pBack + pw;
      }
    }
  }

  // Fall off - respawn
  if (player.y < -12) {
    if (gameState === 'parkour') {
      // Respawn at start
      player.x = 0; player.y = 2; player.z = 0;
      player.vy = 0;
      showToast('You fell! Try again', 'error');
    } else if (gameState === 'lobby') {
      player.x = 0; player.y = 2; player.z = 8;
      player.vy = 0;
    }
  }

  // Portal detection (lobby only)
  if (gameState === 'lobby') {
    for (const portal of portals) {
      const dx = player.x - portal.x;
      const dz = player.z - portal.z;
      const dist = Math.sqrt(dx*dx + dz*dz);
      if (dist < portal.radius + 0.5) {
        if (portal.target === 'parkour') {
          document.exitPointerLock();
          document.getElementById('parkour-select').classList.remove('hidden');
        } else if (portal.target === 'maze') {
          startMaze();
        } else if (portal.target === 'shop') {
          document.exitPointerLock();
          openShop();
        }
        // Push player back
        player.x += (dx / dist) * 2;
        player.z += (dz / dist) * 2;
      }
    }
  }

  // Enemy AI (maze)
  if (gameState === 'maze') {
    enemies.forEach(enemy => {
      const dx = player.x - enemy.x;
      const dz = player.z - enemy.z;
      const dist = Math.sqrt(dx * dx + dz * dz);

      // Simple chase - move toward player, checking wall collisions
      if (dist > 0) {
        const moveX = (dx / dist) * enemy.speed * dt;
        const moveZ = (dz / dist) * enemy.speed * dt;

        // Check wall collision before moving
        let canMoveX = true, canMoveZ = true;
        const ew = 0.3;
        for (const w of mazeWalls) {
          const wl = w.x - w.w/2, wr = w.x + w.w/2;
          const wf = w.z - w.d/2, wb = w.z + w.d/2;

          if (enemy.x + moveX + ew > wl && enemy.x + moveX - ew < wr &&
              enemy.z + ew > wf && enemy.z - ew < wb) canMoveX = false;
          if (enemy.x + ew > wl && enemy.x - ew < wr &&
              enemy.z + moveZ + ew > wf && enemy.z + moveZ - ew < wb) canMoveZ = false;
        }

        if (canMoveX) enemy.x += moveX;
        if (canMoveZ) enemy.z += moveZ;
      }

      // Catch player
      if (dist < 1.2) {
        loseMaze();
      }
    });

    // Check maze exit
    if (mazeExit) {
      const dx = player.x - mazeExit.x;
      const dz = player.z - mazeExit.z;
      if (Math.abs(dx) < mazeExit.w && Math.abs(dz) < mazeExit.d) {
        winMaze();
      }
    }
  }

  // Camera follow
  const camDist = camera.distance;
  camera.targetX = player.x - Math.sin(camera.yaw) * camDist * Math.cos(camera.pitch);
  camera.targetY = player.y + 1 + Math.sin(camera.pitch) * camDist;
  camera.targetZ = player.z - Math.cos(camera.yaw) * camDist * Math.cos(camera.pitch);

  const smooth = 0.12;
  camera.x += (camera.targetX - camera.x) * smooth;
  camera.y += (camera.targetY - camera.y) * smooth;
  camera.z += (camera.targetZ - camera.z) * smooth;
}

// ============================================================
// RENDERING
// ============================================================

function renderScene() {
  // Sky / background
  const time = Date.now() / 1000;

  if (gameState === 'lobby') {
    const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, '#0a0a1a');
    grad.addColorStop(0.5, '#0f0f2d');
    grad.addColorStop(1, '#1a0a2e');
    ctx.fillStyle = grad;
  } else if (gameState === 'parkour') {
    const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, '#0a0505');
    grad.addColorStop(0.7, '#1a0a05');
    grad.addColorStop(1, '#2d1005');
    ctx.fillStyle = grad;
  } else if (gameState === 'maze') {
    const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, '#050508');
    grad.addColorStop(1, '#0a0a15');
    ctx.fillStyle = grad;
  } else {
    ctx.fillStyle = '#0a0a12';
  }
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Collect all renderable objects and sort by distance
  const renderList = [];

  // Platforms
  platforms.forEach(p => {
    const dx = p.x - camera.x;
    const dz = p.z - camera.z;
    const dist = dx*dx + dz*dz;
    if (dist < 10000) {
      renderList.push({ dist, fn: () => drawBox(p.x, p.y, p.z, p.w, p.h, p.d, p.top, p.color, p.side, p.glow ? '#00ffc830' : null) });
    }
  });

  // Maze walls
  mazeWalls.forEach(w => {
    const dx = w.x - camera.x;
    const dz = w.z - camera.z;
    const dist = dx*dx + dz*dz;
    if (dist < 2500) {
      renderList.push({ dist, fn: () => drawBox(w.x, w.y, w.z, w.w, w.h, w.d, '#374151', '#2d3748', '#1a202c') });
    }
  });

  // Maze exit
  if (mazeExit && gameState === 'maze') {
    renderList.push({ dist: 0, fn: () => {
      const pulse = 0.8 + Math.sin(time * 4) * 0.2;
      drawBox(mazeExit.x, 0, mazeExit.z, mazeExit.w, 0.1, mazeExit.d, `rgba(0,255,200,${pulse})`, '#00ffc840', '#00ffc820');
      // Beam of light
      drawBox(mazeExit.x, 0, mazeExit.z, 0.3, 6, 0.3, '#00ffc830', '#00ffc815', '#00ffc815');
    }});
  }

  // Crystals
  crystals.forEach(c => {
    const dx = c.x - camera.x;
    const dz = c.z - camera.z;
    const dist = dx*dx + dz*dz;
    if (dist < 2500) {
      renderList.push({ dist, fn: () => drawCrystal(c.x, c.y, c.z, c.color, c.size) });
    }
  });

  // Portals
  portals.forEach(p => {
    const dx = p.x - camera.x;
    const dz = p.z - camera.z;
    renderList.push({ dist: dx*dx + dz*dz, fn: () => drawPortal(p.x, p.y, p.z, p.radius, p.color, p.label) });
  });

  // Signs
  signs.forEach(s => {
    const dx = s.x - camera.x;
    const dz = s.z - camera.z;
    renderList.push({ dist: dx*dx + dz*dz, fn: () => drawSign(s.x, s.y, s.z, s.text) });
  });

  // Enemies
  enemies.forEach(e => {
    const dx = e.x - camera.x;
    const dz = e.z - camera.z;
    renderList.push({ dist: dx*dx + dz*dz, fn: () => drawEnemy(e) });
  });

  // Player
  renderList.push({
    dist: (player.x - camera.x)**2 + (player.z - camera.z)**2,
    fn: () => drawPlayer()
  });

  // Sort back-to-front
  renderList.sort((a, b) => b.dist - a.dist);
  renderList.forEach(item => item.fn());

  // Lava glow effect (parkour)
  if (gameState === 'parkour') {
    const lavaGlow = 0.1 + Math.sin(time * 2) * 0.05;
    ctx.fillStyle = `rgba(255, 100, 0, ${lavaGlow})`;
    ctx.fillRect(0, canvas.height * 0.7, canvas.width, canvas.height * 0.3);
  }

  // Fog/atmosphere
  if (gameState === 'maze') {
    const fogGrad = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 0, canvas.width/2, canvas.height/2, canvas.width*0.6);
    fogGrad.addColorStop(0, 'rgba(5,5,10,0)');
    fogGrad.addColorStop(1, 'rgba(5,5,10,0.7)');
    ctx.fillStyle = fogGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }
}

// Minimap for maze
function renderMinimap() {
  if (gameState !== 'maze') { document.getElementById('minimap').style.display = 'none'; return; }
  document.getElementById('minimap').style.display = 'block';

  const mc = document.getElementById('minimap');
  const mctx = mc.getContext('2d');
  const SIZE = 15, CELL = 3;
  const scale = mc.width / (SIZE * CELL);

  mctx.fillStyle = 'rgba(8,8,20,0.9)';
  mctx.fillRect(0, 0, mc.width, mc.height);

  // Walls
  mctx.strokeStyle = '#4b5563';
  mctx.lineWidth = 1;
  mazeWalls.forEach(w => {
    mctx.strokeRect(
      (w.x - w.w/2) * scale,
      (w.z - w.d/2) * scale,
      w.w * scale,
      w.d * scale
    );
  });

  // Exit
  if (mazeExit) {
    mctx.fillStyle = '#00ffc8';
    mctx.fillRect(
      (mazeExit.x - 1) * scale,
      (mazeExit.z - 1) * scale,
      2 * scale, 2 * scale
    );
  }

  // Enemies
  enemies.forEach(e => {
    mctx.fillStyle = '#dc2626';
    mctx.beginPath();
    mctx.arc(e.x * scale, e.z * scale, 3, 0, Math.PI * 2);
    mctx.fill();
  });

  // Player
  mctx.fillStyle = '#fbbf24';
  mctx.beginPath();
  mctx.arc(player.x * scale, player.z * scale, 4, 0, Math.PI * 2);
  mctx.fill();
}

// ============================================================
// GAME MODES
// ============================================================

function startParkour(difficulty) {
  parkourDifficulty = difficulty;
  document.getElementById('parkour-select').classList.add('hidden');
  gameState = 'parkour';
  buildParkour(difficulty);
  document.getElementById('btn-back-lobby').style.display = 'block';
  document.getElementById('game-timer').style.display = 'block';
  document.getElementById('instructions').textContent = 'WASD to move · SPACE to jump · Reach the golden platform!';
  gameStartTime = Date.now();
  canvas.requestPointerLock();
}

function closeParkourSelect() {
  document.getElementById('parkour-select').classList.add('hidden');
}

async function winParkour() {
  if (gameState !== 'parkour') return;
  gameState = 'result';
  document.exitPointerLock();
  const reward = PARKOUR_REWARDS[parkourDifficulty];
  const elapsed = ((Date.now() - gameStartTime) / 1000).toFixed(1);

  document.getElementById('game-timer').style.display = 'none';
  document.getElementById('result-title').textContent = '🎉 PARKOUR COMPLETE!';
  document.getElementById('result-text').textContent = `You completed ${parkourDifficulty} difficulty in ${elapsed}s!`;
  document.getElementById('result-reward').textContent = `+${reward} 🪙`;
  document.getElementById('result-overlay').classList.remove('hidden');

  await ensurePlayerData();
  await addCurrency(reward);

  // Update best time
  const key = `parkour_${parkourDifficulty}_best`;
  if (!playerData[key] || parseFloat(elapsed) < playerData[key]) {
    playerData[key] = parseFloat(elapsed);
    await window.dataSdk.update(playerData);
  }
}

function startMaze() {
  gameState = 'maze';
  buildMaze();
  document.getElementById('btn-back-lobby').style.display = 'block';
  document.getElementById('game-timer').style.display = 'block';
  document.getElementById('instructions').textContent = 'WASD to move · Find the green exit · Avoid red enemies!';
  mazeTimer = 0;
  gameStartTime = Date.now();

  if (mazeTimerInterval) clearInterval(mazeTimerInterval);
  mazeTimerInterval = setInterval(() => {
    mazeTimer = ((Date.now() - gameStartTime) / 1000).toFixed(1);
    document.getElementById('game-timer').textContent = `⏱ ${mazeTimer}s`;
  }, 100);
}

async function winMaze() {
  if (gameState !== 'maze') return;
  gameState = 'result';
  document.exitPointerLock();
  if (mazeTimerInterval) clearInterval(mazeTimerInterval);

  document.getElementById('game-timer').style.display = 'none';
  document.getElementById('result-title').textContent = '🎉 MAZE ESCAPED!';
  document.getElementById('result-text').textContent = `You escaped in ${mazeTimer}s!`;
  document.getElementById('result-reward').textContent = `+${MAZE_REWARD} 🪙`;
  document.getElementById('result-overlay').classList.remove('hidden');

  await ensurePlayerData();
  await addCurrency(MAZE_REWARD);
  playerData.maze_wins = (playerData.maze_wins || 0) + 1;
  await window.dataSdk.update(playerData);
}

async function loseMaze() {
  if (gameState !== 'maze') return;
  gameState = 'result';
  document.exitPointerLock();
  if (mazeTimerInterval) clearInterval(mazeTimerInterval);

  document.getElementById('game-timer').style.display = 'none';
  document.getElementById('result-title').textContent = '💀 CAUGHT!';
  document.getElementById('result-text').textContent = 'An enemy caught you! Better luck next time.';
  document.getElementById('result-reward').textContent = '+0 🪙';
  document.getElementById('result-overlay').classList.remove('hidden');
}

function returnToLobby() {
  gameState = 'lobby';
  document.getElementById('result-overlay').classList.add('hidden');
  document.getElementById('btn-back-lobby').style.display = 'none';
  document.getElementById('game-timer').style.display = 'none';
  document.getElementById('instructions').textContent = 'WASD to move · SPACE to jump · Walk into portals to enter';
  if (mazeTimerInterval) clearInterval(mazeTimerInterval);
  buildLobby();
}

// ============================================================
// SHOP
// ============================================================

async function openShop() {
  await ensurePlayerData();
  document.getElementById('shop-overlay').classList.remove('hidden');
  updateCurrencyUI();
  showShopTab('hats');
}

function closeShop() {
  document.getElementById('shop-overlay').classList.add('hidden');
}

function showShopTab(tab) {
  currentShopTab = tab;
  ['hats','masks','faces'].forEach(t => {
    document.getElementById(`tab-${t}`).className = t === tab ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-secondary';
  });
  renderShopItems();
}

function renderShopItems() {
  const container = document.getElementById('shop-items');
  const items = COSMETICS[currentShopTab];
  const type = currentShopTab.slice(0, -1); // hat, mask, face

  container.innerHTML = items.map(item => {
    const owned = isOwned(item.id);
    const equipped = playerData && playerData[`equipped_${type}`] === item.id;
    let btnHtml;
    if (equipped) {
      btnHtml = `<button class="btn btn-sm" style="background:#374151;color:#9ca3af;cursor:default;" disabled>Equipped</button>`;
    } else if (owned) {
      btnHtml = `<button class="btn btn-sm btn-primary" onclick="equipItem('${type}','${item.id}')">Equip</button>`;
    } else {
      btnHtml = `<button class="btn btn-sm btn-secondary" onclick="buyItem('${type}','${item.id}',${item.price})">Buy ${item.price} 🪙</button>`;
    }

    return `
      <div class="shop-item ${owned ? 'owned' : ''} ${equipped ? 'equipped' : ''}">
        <div class="item-preview">${item.emoji}</div>
        <p style="color:#e2e8f0;font-weight:600;margin-bottom:8px;">${item.name}</p>
        ${btnHtml}
      </div>
    `;
  }).join('');
}

async function buyItem(type, id, price) {
  await ensurePlayerData();
  if ((playerData.currency || 0) < price) {
    showToast('Not enough coins!', 'error');
    return;
  }
  const success = await spendCurrency(price);
  if (success) {
    await ownCosmetic(id);
    await equipItem(type, id);
    showToast(`Purchased! -${price} 🪙`, 'success');
  }
}

async function equipItem(type, id) {
  await ensurePlayerData();
  player[type] = id;
  await saveCosmetic(type, id);
  renderShopItems();
  showToast(`Equipped ${id}!`, 'success');
}

// ============================================================
// GAME LOOP
// ============================================================

let lastTime = 0;

function gameLoop(timestamp) {
  const dt = Math.min((timestamp - lastTime) / 1000, 0.05);
  lastTime = timestamp;

  resize();

  if (gameState === 'lobby' || gameState === 'parkour' || gameState === 'maze') {
    updatePhysics(dt);
    renderScene();
    renderMinimap();

    // Timer display for parkour
    if (gameState === 'parkour') {
      const elapsed = ((Date.now() - gameStartTime) / 1000).toFixed(1);
      document.getElementById('game-timer').textContent = `⏱ ${elapsed}s`;
    }
  } else if (gameState === 'result') {
    renderScene(); // Keep showing last scene
  } else if (gameState === 'loading') {
    // Show loading
  }

  requestAnimationFrame(gameLoop);
}

// ============================================================
// INIT
// ============================================================

async function init() {
  // Show loading for 2s
  setTimeout(async () => {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('hud').classList.remove('hidden');
    gameState = 'lobby';
    buildLobby();
    await ensurePlayerData();
    showToast('Welcome to Nexus Arena!', 'info');
  }, 2200);

  requestAnimationFrame(gameLoop);
}

