  <script>
// ============================================================
// NEXUS ARENA - 3D Action Adventure Game
// ============================================================

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

// --- Game State ---
let gameState = 'loading'; // loading, lobby, parkour, maze
let playerData = null;
let dataRecords = [];
let currentShopTab = 'hats';
let parkourDifficulty = 'easy';
let mazeTimer = 0;
let mazeTimerInterval = null;
let gameStartTime = 0;

// --- Player ---
const player = {
  x: 0, y: 1.5, z: 0,
  vx: 0, vy: 0, vz: 0,
  yaw: 0, pitch: 0,
  grounded: false,
  width: 0.6, height: 1.6,
  speed: 4.5,
  jumpForce: 8,
  hat: 'none', mask: 'none', face: 'default'
};

// --- Camera ---
const camera = {
  x: 0, y: 3, z: 6,
  targetX: 0, targetY: 3, targetZ: 6,
  yaw: 0, pitch: 0.3,
  distance: 5,
  fov: 70
};

// --- Input ---
const keys = {};
let mouseX = 0, mouseY = 0;
let isPointerLocked = false;

// --- World Data ---
let platforms = [];
let portals = [];
let enemies = [];
let crystals = [];
let signs = [];
let mazeWalls = [];
let mazeExit = null;
let mazeGrid = [];
const GRAVITY = -20;

// --- Cosmetics ---
const COSMETICS = {
  hats: [
    { id:'crown', name:'Crown', emoji:'👑', price:100 },
    { id:'tophat', name:'Top Hat', emoji:'🎩', price:80 },
    { id:'cap', name:'Cap', emoji:'🧢', price:50 },
    { id:'wizard', name:'Wizard Hat', emoji:'🧙', price:150 },
    { id:'helmet', name:'Knight Helm', emoji:'⛑️', price:200 },
  ],
  masks: [
    { id:'robot', name:'Robot', emoji:'🤖', price:120 },
    { id:'alien', name:'Alien', emoji:'👽', price:90 },
    { id:'ninja', name:'Ninja', emoji:'🥷', price:110 },
    { id:'skull', name:'Skull', emoji:'💀', price:160 },
  ],
  faces: [
    { id:'cool', name:'Cool', emoji:'😎', price:60 },
    { id:'fire', name:'Fire', emoji:'🔥', price:70 },
    { id:'star', name:'Star Eyes', emoji:'🤩', price:80 },
    { id:'ghost', name:'Ghost', emoji:'👻', price:100 },
  ]
};

const PARKOUR_REWARDS = { easy: 50, medium: 120, hard: 250 };
const MAZE_REWARD = 180;

// --- Default Player Data ---
function getDefaultPlayerData() {
  return {
    player_id: 'player_1',
    currency: 0,
    owned_cosmetics: '',
    equipped_hat: 'none',
    equipped_mask: 'none',
    equipped_face: 'default',
    parkour_easy_best: 0,
    parkour_medium_best: 0,
    parkour_hard_best: 0,
    maze_wins: 0
  };
}

// --- Element SDK ---
const defaultConfig = {
  game_title: 'NEXUS ARENA',
  lobby_welcome: 'Welcome, adventurer!',
  background_color: '#0a0a12',
  surface_color: '#0f0f23',
  text_color: '#e2e8f0',
  primary_action_color: '#00ffc8',
  secondary_action_color: '#a78bfa',
  font_family: 'Orbitron',
  font_size: 16
};

window.elementSdk.init({
  defaultConfig,
  onConfigChange: async (config) => {
    const title = config.game_title || defaultConfig.game_title;
    const el = document.getElementById('loading-title');
    if (el) el.textContent = title;
    document.body.style.background = config.background_color || defaultConfig.background_color;
    const font = config.font_family || defaultConfig.font_family;
    document.querySelectorAll('.hud-panel, .btn, .menu-card h2, #game-timer, #instructions').forEach(e => {
      e.style.fontFamily = `${font}, Orbitron, sans-serif`;
    });
  },
  mapToCapabilities: (config) => ({
    recolorables: [
      { get: () => config.background_color || defaultConfig.background_color, set: v => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
      { get: () => config.surface_color || defaultConfig.surface_color, set: v => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
      { get: () => config.text_color || defaultConfig.text_color, set: v => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
      { get: () => config.primary_action_color || defaultConfig.primary_action_color, set: v => { config.primary_action_color = v; window.elementSdk.setConfig({ primary_action_color: v }); } },
      { get: () => config.secondary_action_color || defaultConfig.secondary_action_color, set: v => { config.secondary_action_color = v; window.elementSdk.setConfig({ secondary_action_color: v }); } },
    ],
    borderables: [],
    fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: v => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
    fontSizeable: { get: () => config.font_size || defaultConfig.font_size, set: v => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); } },
  }),
  mapToEditPanelValues: (config) => new Map([
    ['game_title', config.game_title || defaultConfig.game_title],
    ['lobby_welcome', config.lobby_welcome || defaultConfig.lobby_welcome],
  ])
});

// --- Data SDK ---
const dataHandler = {
  onDataChanged(data) {
    dataRecords = data;
    if (data.length > 0) {
      playerData = data[0];
      player.hat = playerData.equipped_hat || 'none';
      player.mask = playerData.equipped_mask || 'none';
      player.face = playerData.equipped_face || 'default';
      updateCurrencyUI();
    }
  }
};

async function initDataSDK() {
  const result = await window.dataSdk.init(dataHandler);
  if (!result.isOk) console.error('Data SDK init failed');
}
initDataSDK();

function updateCurrencyUI() {
  if (!playerData) return;
  document.getElementById('currency-amount').textContent = playerData.currency || 0;
  document.getElementById('shop-currency').textContent = playerData.currency || 0;
}

async function ensurePlayerData() {
  if (!playerData) {
    if (dataRecords.length === 0) {
      const result = await window.dataSdk.create(getDefaultPlayerData());
      if (!result.isOk) { showToast('Failed to create save data', 'error'); }
    } else {
      playerData = dataRecords[0];
    }
  }
}

async function addCurrency(amount) {
  if (!playerData) return;
  playerData.currency = (playerData.currency || 0) + amount;
  const result = await window.dataSdk.update(playerData);
  if (!result.isOk) showToast('Save failed', 'error');
  updateCurrencyUI();
}

async function spendCurrency(amount) {
  if (!playerData || (playerData.currency || 0) < amount) return false;
  playerData.currency -= amount;
  const result = await window.dataSdk.update(playerData);
  if (!result.isOk) { showToast('Save failed', 'error'); return false; }
  updateCurrencyUI();
  return true;
}

async function saveCosmetic(type, id) {
  if (!playerData) return;
  playerData[`equipped_${type}`] = id;
  await window.dataSdk.update(playerData);
}

async function ownCosmetic(id) {
  if (!playerData) return;
  let owned = playerData.owned_cosmetics ? playerData.owned_cosmetics.split(',') : [];
  if (!owned.includes(id)) { owned.push(id); playerData.owned_cosmetics = owned.join(','); }
  await window.dataSdk.update(playerData);
}

function isOwned(id) {
  if (!playerData) return false;
  const owned = playerData.owned_cosmetics ? playerData.owned_cosmetics.split(',') : [];
  return owned.includes(id);
}

// --- Toast ---
function showToast(msg, type='info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  toast.textContent = msg;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

// --- Resize ---
function resize() {
  canvas.width = canvas.clientWidth;
  canvas.height = canvas.clientHeight;
}
window.addEventListener('resize', resize);
resize();

// --- Input ---
document.addEventListener('keydown', e => {
  keys[e.code] = true;
  if (e.code === 'Space') e.preventDefault();
});
document.addEventListener('keyup', e => keys[e.code] = false);

canvas.addEventListener('click', () => {
  if (gameState === 'lobby' || gameState === 'parkour' || gameState === 'maze') {
    canvas.requestPointerLock();
  }
});
document.addEventListener('pointerlockchange', () => {
  isPointerLocked = document.pointerLockElement === canvas;
  document.getElementById('crosshair').style.display = isPointerLocked ? 'block' : 'none';
});
document.addEventListener('mousemove', e => {
  if (isPointerLocked) {
    camera.yaw -= e.movementX * 0.003;
    camera.pitch = Math.max(-0.8, Math.min(1.0, camera.pitch - e.movementY * 0.003));
  }
});

// ============================================================
// 3D RENDERING ENGINE (Software Rasterizer)
// ============================================================

// Projection
function project(x, y, z) {
  // Transform relative to camera
  const dx = x - camera.x;
  const dy = y - camera.y;
  const dz = z - camera.z;

  // Rotate by camera yaw
  const cosY = Math.cos(-camera.yaw);
  const sinY = Math.sin(-camera.yaw);
  let rx = dx * cosY - dz * sinY;
  let rz = dx * sinY + dz * cosY;
  let ry = dy;

  // Rotate by pitch
  const cosP = Math.cos(-camera.pitch);
  const sinP = Math.sin(-camera.pitch);
  let ry2 = ry * cosP - rz * sinP;
  let rz2 = ry * sinP + rz * cosP;

  if (rz2 < 0.1) return null;

  const fov = camera.fov * (Math.PI / 180);
  const scale = canvas.width / (2 * Math.tan(fov / 2));
  const sx = canvas.width / 2 + (rx * scale) / rz2;
  const sy = canvas.height / 2 - (ry2 * scale) / rz2;

  return { x: sx, y: sy, z: rz2 };
}

// Draw filled quad (4 world-space points, color)
function drawQuad(p1, p2, p3, p4, color, outline) {
  const s1 = project(p1[0], p1[1], p1[2]);
  const s2 = project(p2[0], p2[1], p2[2]);
  const s3 = project(p3[0], p3[1], p3[2]);
  const s4 = project(p4[0], p4[1], p4[2]);
  if (!s1 || !s2 || !s3 || !s4) return;

  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.moveTo(s1.x, s1.y);
  ctx.lineTo(s2.x, s2.y);
  ctx.lineTo(s3.x, s3.y);
  ctx.lineTo(s4.x, s4.y);
  ctx.closePath();
  ctx.fill();
  if (outline) {
    ctx.strokeStyle = outline;
    ctx.lineWidth = 1;
    ctx.stroke();
  }
}

// Draw a box
function drawBox(x, y, z, w, h, d, topColor, sideColor1, sideColor2, outline) {
  const hw = w/2, hd = d/2;

  // Sort faces by distance (painter's algorithm for a single box)
  const faces = [];
  // Top
  faces.push({ z: y+h, fn: () => drawQuad([x-hw,y+h,z-hd],[x+hw,y+h,z-hd],[x+hw,y+h,z+hd],[x-hw,y+h,z+hd], topColor, outline) });
  // Front
  faces.push({ z: z+hd, fn: () => drawQuad([x-hw,y,z+hd],[x+hw,y,z+hd],[x+hw,y+h,z+hd],[x-hw,y+h,z+hd], sideColor1, outline) });
  // Back
  faces.push({ z: z-hd, fn: () => drawQuad([x-hw,y,z-hd],[x+hw,y,z-hd],[x+hw,y+h,z-hd],[x-hw,y+h,z-hd], sideColor1, outline) });
  // Left
  faces.push({ z: x-hw, fn: () => drawQuad([x-hw,y,z-hd],[x-hw,y,z+hd],[x-hw,y+h,z+hd],[x-hw,y+h,z-hd], sideColor2, outline) });
  // Right
  faces.push({ z: x+hw, fn: () => drawQuad([x+hw,y,z-hd],[x+hw,y,z+hd],[x+hw,y+h,z+hd],[x+hw,y+h,z-hd], sideColor2, outline) });

  faces.forEach(f => f.fn());
}

// Draw cylinder approximation (hexagonal)
function drawCylinder(x, y, z, radius, height, color, topColor) {
  const segments = 8;
  for (let i = 0; i < segments; i++) {
    const a1 = (i / segments) * Math.PI * 2;
    const a2 = ((i + 1) / segments) * Math.PI * 2;
    const x1 = x + Math.cos(a1) * radius;
    const z1 = z + Math.sin(a1) * radius;
    const x2 = x + Math.cos(a2) * radius;
    const z2 = z + Math.sin(a2) * radius;

    // Side face
    drawQuad([x1,y,z1],[x2,y,z2],[x2,y+height,z2],[x1,y+height,z1], color);
    // Top face
    drawQuad([x,y+height,z],[x1,y+height,z1],[x2,y+height,z2],[x,y+height,z], topColor || color);
  }
}

// Draw portal (glowing ring)
function drawPortal(x, y, z, radius, color, label) {
  const segments = 16;
  const thickness = 0.15;
  const time = Date.now() / 1000;

  // Outer ring
  for (let i = 0; i < segments; i++) {
    const a1 = (i / segments) * Math.PI * 2;
    const a2 = ((i + 1) / segments) * Math.PI * 2;
    const pulse = 1 + Math.sin(time * 3 + i * 0.5) * 0.05;
    const r = radius * pulse;
    const ri = (radius - thickness) * pulse;

    const x1o = x + Math.cos(a1) * r;
    const y1o = y + Math.sin(a1) * r;
    const x2o = x + Math.cos(a2) * r;
    const y2o = y + Math.sin(a2) * r;
    const x1i = x + Math.cos(a1) * ri;
    const y1i = y + Math.sin(a1) * ri;
    const x2i = x + Math.cos(a2) * ri;
    const y2i = y + Math.sin(a2) * ri;

    drawQuad([x1o,y1o,z],[x2o,y2o,z],[x2i,y2i,z],[x1i,y1i,z], color);
  }

  // Inner glow
  const sp = project(x, y, z);
  if (sp && sp.z > 0) {
    const screenR = (radius * 400) / sp.z;
    const grad = ctx.createRadialGradient(sp.x, sp.y, 0, sp.x, sp.y, screenR);
    grad.addColorStop(0, color + '60');
    grad.addColorStop(0.6, color + '20');
    grad.addColorStop(1, color + '00');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, screenR, 0, Math.PI * 2);
    ctx.fill();

    // Label
    if (label && sp.z < 20) {
      ctx.fillStyle = '#fff';
      ctx.font = `bold ${Math.max(10, 18 - sp.z)}px Orbitron`;
      ctx.textAlign = 'center';
      ctx.fillText(label, sp.x, sp.y - screenR - 10);
    }
  }
}

// Draw player character
function drawPlayer() {
  const time = Date.now() / 1000;
  const bob = player.grounded ? Math.sin(time * 8) * 0.05 : 0;

  // Body
  drawBox(player.x, player.y - 0.8 + bob, player.z, 0.5, 0.7, 0.3, '#2563eb', '#1d4ed8', '#1e40af');
  // Head
  drawBox(player.x, player.y + bob, player.z, 0.4, 0.4, 0.35, '#fcd34d', '#f59e0b', '#d97706');
  // Legs
  const legAnim = player.grounded ? Math.sin(time * 10) * 0.1 : 0;
  drawBox(player.x - 0.12, player.y - 1.5 + bob + legAnim, player.z, 0.18, 0.7, 0.2, '#1e293b', '#0f172a', '#1e293b');
  drawBox(player.x + 0.12, player.y - 1.5 + bob - legAnim, player.z, 0.18, 0.7, 0.2, '#1e293b', '#0f172a', '#1e293b');

  // Hat cosmetic
  if (player.hat !== 'none') {
    const hatItem = COSMETICS.hats.find(h => h.id === player.hat);
    if (hatItem) {
      const hp = project(player.x, player.y + 0.55 + bob, player.z);
      if (hp && hp.z > 0) {
        const s = Math.max(12, 32 - hp.z * 2);
        ctx.font = `${s}px serif`;
        ctx.textAlign = 'center';
        ctx.fillText(hatItem.emoji, hp.x, hp.y);
      }
    }
  }
  // Face
  if (player.face !== 'default') {
    const faceItem = COSMETICS.faces.find(f => f.id === player.face);
    if (faceItem) {
      const fp = project(player.x, player.y + 0.15 + bob, player.z + 0.2);
      if (fp && fp.z > 0) {
        const s = Math.max(8, 20 - fp.z * 2);
        ctx.font = `${s}px serif`;
        ctx.textAlign = 'center';
        ctx.fillText(faceItem.emoji, fp.x, fp.y);
      }
    }
  }
}

// Draw crystal
function drawCrystal(x, y, z, color, size) {
  const time = Date.now() / 1000;
  const glow = 0.6 + Math.sin(time * 2 + x + z) * 0.4;
  const s = size || 0.3;

  // Diamond shape
  drawQuad([x,y,z-s],[x+s,y+s*1.5,z],[x,y+s*3,z],[x-s,y+s*1.5,z], color + Math.floor(glow * 255).toString(16).padStart(2,'0'));

  // Glow
  const sp = project(x, y + s * 1.5, z);
  if (sp && sp.z > 0 && sp.z < 30) {
    const r = (s * 300) / sp.z;
    const grad = ctx.createRadialGradient(sp.x, sp.y, 0, sp.x, sp.y, r);
    grad.addColorStop(0, color + '40');
    grad.addColorStop(1, color + '00');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, r, 0, Math.PI * 2);
    ctx.fill();
  }
}

// Draw enemy (red glowing entity)
function drawEnemy(enemy) {
  const time = Date.now() / 1000;
  const hover = Math.sin(time * 3 + enemy.x) * 0.15;

  // Body
  drawBox(enemy.x, enemy.y + hover, enemy.z, 0.6, 0.9, 0.4, '#dc2626', '#b91c1c', '#991b1b');
  // Eyes
  const ep = project(enemy.x, enemy.y + 0.7 + hover, enemy.z + 0.25);
  if (ep && ep.z > 0) {
    const s = Math.max(3, 10 - ep.z);
    ctx.fillStyle = '#fef08a';
    ctx.beginPath();
    ctx.arc(ep.x - s, ep.y, s * 0.5, 0, Math.PI * 2);
    ctx.arc(ep.x + s, ep.y, s * 0.5, 0, Math.PI * 2);
    ctx.fill();
  }

  // Glow
  const sp = project(enemy.x, enemy.y + 0.5, enemy.z);
  if (sp && sp.z > 0 && sp.z < 25) {
    const r = 200 / sp.z;
    const grad = ctx.createRadialGradient(sp.x, sp.y, 0, sp.x, sp.y, r);
    grad.addColorStop(0, '#dc262640');
    grad.addColorStop(1, '#dc262600');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(sp.x, sp.y, r, 0, Math.PI * 2);
    ctx.fill();
  }
}

// Draw sign
function drawSign(x, y, z, text) {
  // Post
  drawBox(x, y, z, 0.1, 1.5, 0.1, '#78350f', '#92400e', '#78350f');
  // Board
  drawBox(x, y + 1.5, z, 1.5, 0.8, 0.08, '#451a03', '#78350f', '#78350f');

  const sp = project(x, y + 1.8, z + 0.1);
  if (sp && sp.z > 0 && sp.z < 15) {
    const fontSize = Math.max(8, 14 - sp.z);
    ctx.fillStyle = '#fcd34d';
    ctx.font = `bold ${fontSize}px Rajdhani`;
    ctx.textAlign = 'center';
    const lines = text.split('\n');
    lines.forEach((line, i) => {
      ctx.fillText(line, sp.x, sp.y + i * (fontSize + 2) - ((lines.length - 1) * fontSize) / 2);
    });
  }
}

