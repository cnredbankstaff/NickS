  <style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; width:100%; overflow:hidden; font-family:'Rajdhani',sans-serif; background:#0a0a12; }
canvas { display:block; width:100%; height:100%; }
#game-container { position:relative; width:100%; height:100%; }

/* HUD */
#hud { position:absolute; top:0; left:0; right:0; padding:12px 20px; display:flex; justify-content:space-between; align-items:center; pointer-events:none; z-index:10; }
#hud > * { pointer-events:auto; }
.hud-panel { background:rgba(8,8,20,0.85); border:1px solid rgba(0,255,200,0.25); border-radius:8px; padding:8px 16px; backdrop-filter:blur(8px); }
.currency-display { display:flex; align-items:center; gap:8px; color:#00ffc8; font-family:'Orbitron',sans-serif; font-size:18px; font-weight:700; }
.currency-icon { width:24px; height:24px; background:radial-gradient(circle,#ffd700,#ff8c00); border-radius:50%; border:2px solid #fff3; }

/* Crosshair */
#crosshair { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:6px; height:6px; border:2px solid rgba(0,255,200,0.6); border-radius:50%; pointer-events:none; z-index:5; display:none; }

/* Menus / Overlays */
.overlay { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; z-index:50; background:rgba(5,5,15,0.92); backdrop-filter:blur(12px); }
.overlay.hidden { display:none; }
.menu-card { background:linear-gradient(135deg,rgba(15,15,35,0.95),rgba(25,20,50,0.95)); border:1px solid rgba(0,255,200,0.2); border-radius:16px; padding:32px; max-width:600px; width:90%; max-height:85%; overflow-y:auto; }
.menu-card h2 { font-family:'Orbitron',sans-serif; color:#00ffc8; font-size:28px; margin-bottom:16px; text-align:center; }
.menu-card h3 { font-family:'Orbitron',sans-serif; color:#a78bfa; font-size:18px; margin:12px 0 8px; }

.btn { font-family:'Orbitron',sans-serif; padding:10px 24px; border:none; border-radius:8px; cursor:pointer; font-size:14px; font-weight:700; transition:all 0.2s; text-transform:uppercase; letter-spacing:1px; }
.btn-primary { background:linear-gradient(135deg,#00ffc8,#00b894); color:#0a0a12; }
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 4px 20px rgba(0,255,200,0.4); }
.btn-secondary { background:linear-gradient(135deg,#a78bfa,#7c3aed); color:#fff; }
.btn-secondary:hover { transform:translateY(-2px); box-shadow:0 4px 20px rgba(167,139,250,0.4); }
.btn-danger { background:linear-gradient(135deg,#f87171,#dc2626); color:#fff; }
.btn-danger:hover { transform:translateY(-2px); box-shadow:0 4px 20px rgba(248,113,113,0.4); }
.btn-sm { padding:6px 14px; font-size:11px; }

/* Signs */
.sign-text { color:#e2e8f0; font-size:14px; line-height:1.5; }

/* Shop items */
.shop-item { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:16px; text-align:center; transition:all 0.2s; cursor:pointer; }
.shop-item:hover { border-color:rgba(0,255,200,0.4); background:rgba(0,255,200,0.05); }
.shop-item.owned { border-color:rgba(0,255,200,0.5); background:rgba(0,255,200,0.08); }
.shop-item.equipped { border-color:#ffd700; background:rgba(255,215,0,0.1); box-shadow:0 0 12px rgba(255,215,0,0.2); }
.item-preview { width:64px; height:64px; margin:0 auto 8px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:36px; }

/* Difficulty cards */
.diff-card { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:20px; text-align:center; transition:all 0.2s; cursor:pointer; }
.diff-card:hover { transform:translateY(-4px); }
.diff-easy { border-color:rgba(52,211,153,0.4); }
.diff-easy:hover { background:rgba(52,211,153,0.1); box-shadow:0 8px 24px rgba(52,211,153,0.2); }
.diff-medium { border-color:rgba(251,191,36,0.4); }
.diff-medium:hover { background:rgba(251,191,36,0.1); box-shadow:0 8px 24px rgba(251,191,36,0.2); }
.diff-hard { border-color:rgba(248,113,113,0.4); }
.diff-hard:hover { background:rgba(248,113,113,0.1); box-shadow:0 8px 24px rgba(248,113,113,0.2); }

/* Toast */
#toast-container { position:absolute; bottom:80px; left:50%; transform:translateX(-50%); z-index:100; display:flex; flex-direction:column; gap:8px; align-items:center; pointer-events:none; }
.toast { padding:10px 24px; border-radius:8px; font-family:'Orbitron',sans-serif; font-size:13px; font-weight:700; animation:toastIn 0.3s ease, toastOut 0.3s ease 2.7s forwards; white-space:nowrap; }
.toast-success { background:rgba(0,255,200,0.9); color:#0a0a12; }
.toast-error { background:rgba(248,113,113,0.9); color:#fff; }
.toast-info { background:rgba(167,139,250,0.9); color:#fff; }
@keyframes toastIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
@keyframes toastOut { from { opacity:1; } to { opacity:0; } }

/* Game timer */
#game-timer { position:absolute; top:60px; left:50%; transform:translateX(-50%); z-index:10; font-family:'Orbitron',sans-serif; font-size:24px; color:#00ffc8; text-shadow:0 0 12px rgba(0,255,200,0.5); display:none; }

/* Instructions */
#instructions { position:absolute; bottom:20px; left:50%; transform:translateX(-50%); z-index:10; color:rgba(255,255,255,0.5); font-size:12px; font-family:'Orbitron',sans-serif; pointer-events:none; letter-spacing:1px; }

/* Minimap */
#minimap { position:absolute; bottom:20px; right:20px; z-index:10; border:2px solid rgba(0,255,200,0.3); border-radius:8px; background:rgba(8,8,20,0.8); display:none; }

/* Loading screen */
#loading { position:absolute; inset:0; background:#0a0a12; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:200; }
#loading h1 { font-family:'Orbitron',sans-serif; font-size:48px; color:#00ffc8; margin-bottom:16px; text-shadow:0 0 30px rgba(0,255,200,0.5); }
#loading p { color:#a78bfa; font-family:'Rajdhani',sans-serif; font-size:18px; }
.loading-bar { width:300px; height:4px; background:rgba(255,255,255,0.1); border-radius:2px; margin-top:24px; overflow:hidden; }
.loading-fill { height:100%; background:linear-gradient(90deg,#00ffc8,#a78bfa); border-radius:2px; animation:loadFill 2s ease forwards; }
@keyframes loadFill { from { width:0; } to { width:100%; } }

/* Scrollbar */
::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:rgba(0,255,200,0.3); border-radius:3px; }
</style>
